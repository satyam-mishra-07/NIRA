# =========================
# LLM SETTINGS
# =========================

LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

PRIMARY_MODEL=deepseek/deepseek-chat-v3-0324
FALLBACK_MODEL=qwen/qwen3-32b

LOCAL_FALLBACK_MODEL=phi3:mini

LLM_TIMEOUT=60
REQUEST_TIMEOUT=30

# =========================
# MEMORY
# =========================
MEMORY_DB=chromadb
MEMORY_PATH=./memory/chroma
USER_PROFILE_PATH=./memory/profiles/user_profile.json

MAX_CONTEXT_MESSAGES=15

# =========================
# VOICE SETTINGS
# =========================

WAKE_WORD=hey nira

STT_PROVIDER=whisper
WHISPER_MODEL=small

TTS_PROVIDER=piper

# =========================
# PLAYWRIGHT
# =========================

BROWSER_PROVIDER=playwright
BROWSER_HEADLESS=false

ALLOW_BROWSER_AUTOMATION=true

# =========================
# SECURITY
# =========================

SAFE_MODE=true

CONFIRM_FILE_DELETE=true
ALLOW_TERMINAL_EXECUTION=false

ALLOWED_DIRECTORIES=./workspace,./projects

# =========================
# PATHS
# =========================

SAFE_WORKSPACE=./workspace
LOG_PATH=./logs

# =========================
# DEBUG
# =========================

DEBUG=true
STREAM_OUTPUT=true
LOG_LEVEL=INFO